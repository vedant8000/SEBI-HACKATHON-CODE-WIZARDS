# MongoDB (required — the datastore runs on MongoDB)
MONGODB_URI=
# MONGODB_DB=siim

# Auth: secret used to sign session tokens (any long random string)
AUTH_SECRET=

# AI provider: gemini | anthropic | openai
# Required for AI classification, chunk-wise fact extraction, draft generation and the assistant.
AI_PROVIDER=gemini

# Multiple Gemini keys are supported — calls rotate to the next key automatically
# whenever one hits its free-tier rate limit (recommended: 2-3 keys).
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# or comma-separated: GEMINI_API_KEYS=key1,key2,key3
# GEMINI_MODEL=gemini-flash-lite-latest

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
